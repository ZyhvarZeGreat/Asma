# Zoho Mail SMTP (India) — from Mail Accounts → SMTP in Zoho
ZOHO_SMTP_HOST=smtppro.zoho.in
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=admin@asmacreativo.com
ZOHO_SMTP_PASS=

# Inbox that receives new applications (change anytime — e.g. admin@asmacreativo.com)
QUESTIONNAIRE_NOTIFY_TO=admin@asmacreativo.com

# Optional: Calendly after submit (defaults to ASMA booking link if unset)
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/asmacreativo-info/30-minutes-meeting

# Optional: external intake forms (skip built-in questionnaire when set)
# NEXT_PUBLIC_TYPEFORM_URL=
# NEXT_PUBLIC_JOTFORM_URL=
